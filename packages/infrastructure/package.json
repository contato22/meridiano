{
  "name": "@meridiano/infrastructure",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@meridiano/application": "workspace:*",
    "@meridiano/db": "workspace:*",
    "@meridiano/domain": "workspace:*",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.15",
    "vitest": "^2.1.8"
  }
}
