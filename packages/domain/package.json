{
  "name": "@meridiano/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./money": {
      "types": "./dist/money/index.d.ts",
      "import": "./dist/money/index.js"
    },
    "./cpf": {
      "types": "./dist/cpf/index.d.ts",
      "import": "./dist/cpf/index.js"
    },
    "./cnpj": {
      "types": "./dist/cnpj/index.d.ts",
      "import": "./dist/cnpj/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc -b tsconfig.json"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^3.23.2",
    "vitest": "^2.1.8"
