# ============================================================================
# Meridiano — environment variables (copy to .env.local and fill in)
# ============================================================================
# NEVER commit .env or .env.local. The .gitignore already excludes them.
# This .env.example is the only file in the repo that documents the full set.

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# Public URL of the app (used by Clerk callbacks, webhook origin check, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Supabase (PostgreSQL)
# ----------------------------------------------------------------------------
# Direct connection — used by Drizzle for migrations + server-side queries.
# Get from Supabase dashboard → Project Settings → Database → Connection string
# (use the "URI" mode with the pooled port 6543 for serverless workloads).
DATABASE_URL=postgres://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Direct (non-pooled) — only used by migration scripts, since pooled
# connections don't support some DDL. Omit if you don't run migrations from
# this env.
DATABASE_URL_DIRECT=postgres://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase project URL (e.g. https://abcdefghij.supabase.co)
SUPABASE_URL=

# Anon (public) key — safe to expose to the browser; RLS does the protection.
SUPABASE_ANON_KEY=

# Service role key — server-only. NEVER expose to the browser. Used only by
# webhook handlers and admin scripts that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Clerk (auth + organizations)
# ----------------------------------------------------------------------------
# Get from Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook signing secret. Get from Clerk dashboard → Webhooks → (your endpoint)
# → Signing Secret. Used to verify webhook authenticity via svix.
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk routing — keep aligned with the (auth) route group in apps/web.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ----------------------------------------------------------------------------
# Observability (PR-D scope, listed here so the example is complete)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# AXIOM_TOKEN=
# AXIOM_DATASET=

# ----------------------------------------------------------------------------
# Inngest (PR-D scope)
# ----------------------------------------------------------------------------
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
